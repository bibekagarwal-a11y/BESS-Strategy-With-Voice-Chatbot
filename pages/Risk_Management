"""
Risk Management Module for BESS Strategy Platform

This module provides comprehensive risk management capabilities:
- Value at Risk (VaR) calculations
- Conditional Value at Risk (CVaR)
- Stress testing scenarios
- Correlation analysis
- Position limit monitoring
- Portfolio risk optimization
"""

import numpy as np
import pandas as pd
from typing import Dict, List, Optional, Tuple
from dataclasses import dataclass
from datetime import datetime, timedelta
from scipy import stats
import warnings
warnings.filterwarnings('ignore')

@dataclass
class RiskLimits:
    """Risk limits configuration."""
    max_position_size: float = 10.0  # MW
    max_daily_loss: float = 10000.0  # EUR
    max_drawdown: float = 50000.0  # EUR
    max_var_95: float = 5000.0  # EUR
    max_correlation: float = 0.8  # Between positions
    min_liquidity: float = 100.0  # MW minimum market depth

@dataclass
class StressScenario:
    """Stress testing scenario."""
    name: str
    description: str
    price_shock: float  # Percentage change
    volatility_shock: float  # Multiplier
    correlation_shock: float  # Change in correlation
    duration_days: int = 1

class RiskManager:
    """Comprehensive risk management system."""
    
    def __init__(self, risk_limits: RiskLimits = None):
        self.limits = risk_limits or RiskLimits()
        self.stress_scenarios = self._create_default_scenarios()
        self.positions = {}
        self.risk_metrics = {}
        
    def _create_default_scenarios(self) -> List[StressScenario]:
        """Create default stress testing scenarios."""
        return [
            StressScenario(
                name="market_crash",
                description="20% price drop with high volatility",
                price_shock=-0.20,
                volatility_shock=2.0,
                correlation_shock=0.3,
                duration_days=5
            ),
            StressScenario(
                name="price_spike",
                description="50% price increase with moderate volatility",
                price_shock=0.50,
                volatility_shock=1.5,
                correlation_shock=0.2,
                duration_days=2
            ),
            StressScenario(
                name="high_volatility",
                description="Normal prices but 3x volatility",
                price_shock=0.0,
                volatility_shock=3.0,
                correlation_shock=0.1,
                duration_days=10
            ),
            StressScenario(
                name="correlation_breakdown",
                description="Prices normal but correlations increase",
                price_shock=0.0,
                volatility_shock=1.0,
                correlation_shock=0.5,
                duration_days=7
            ),
            StressScenario(
                name="extreme_weather",
                description="Cold snap with high demand",
                price_shock=0.30,
                volatility_shock=2.5,
                correlation_shock=0.4,
                duration_days=3
            )
        ]
    
    def calculate_var(self, returns: np.ndarray, confidence: float = 0.95, 
                     method: str = 'historical') -> float:
        """Calculate Value at Risk."""
        if len(returns) == 0:
            return 0.0
        
        if method == 'historical':
            # Historical VaR
            var = np.percentile(returns, (1 - confidence) * 100)
            return var
        
        elif method == 'parametric':
            # Parametric VaR (assumes normal distribution)
            mean = np.mean(returns)
            std = np.std(returns)
            z_score = stats.norm.ppf(1 - confidence)
            var = mean + z_score * std
            return var
        
        elif method == 'cornish_fisher':
            # Cornish-Fisher VaR (adjusts for skewness and kurtosis)
            mean = np.mean(returns)
            std = np.std(returns)
            skew = stats.skew(returns)
            kurt = stats.kurtosis(returns)
            
            z = stats.norm.ppf(1 - confidence)
            z_cf = (z + (z**2 - 1) * skew / 6 + 
                   (z**3 - 3*z) * kurt / 24 - 
                   (2*z**3 - 5*z) * skew**2 / 36)
            
            var = mean + z_cf * std
            return var
        
        else:
            raise ValueError(f"Unknown VaR method: {method}")
    
    def calculate_cvar(self, returns: np.ndarray, confidence: float = 0.95) -> float:
        """Calculate Conditional Value at Risk (Expected Shortfall)."""
        var = self.calculate_var(returns, confidence, method='historical')
        tail_returns = returns[returns <= var]
        
        if len(tail_returns) == 0:
            return var
        
        return np.mean(tail_returns)
    
    def calculate_portfolio_var(self, positions: Dict[str, Dict], 
                               returns: Dict[str, np.ndarray],
                               confidence: float = 0.95) -> Dict:
        """Calculate portfolio VaR considering correlations."""
        if not positions or not returns:
            return {'var': 0.0, 'cvar': 0.0}
        
        # Create returns DataFrame
        returns_df = pd.DataFrame(returns)
        
        # Calculate weights based on position sizes
        total_exposure = sum(pos['size'] for pos in positions.values())
        weights = np.array([positions[area]['size'] / total_exposure 
                           for area in positions.keys()])
        
        # Calculate portfolio returns
        portfolio_returns = returns_df.dot(weights)
        
        # Calculate VaR and CVaR
        var = self.calculate_var(portfolio_returns.values, confidence)
        cvar = self.calculate_cvar(portfolio_returns.values, confidence)
        
        # Calculate contribution to risk by each position
        marginal_var = {}
        for i, area in enumerate(positions.keys()):
            # Calculate marginal VaR by bumping position
            bump = 0.01  # 1% bump
            weights_bumped = weights.copy()
            weights_bumped[i] += bump
            weights_bumped = weights_bumped / weights_bumped.sum()  # Renormalize
            
            portfolio_returns_bumped = returns_df.dot(weights_bumped)
            var_bumped = self.calculate_var(portfolio_returns_bumped.values, confidence)
            
            marginal_var[area] = (var_bumped - var) / bump
        
        return {
            'var': var,
            'cvar': cvar,
            'marginal_var': marginal_var,
            'diversification_benefit': 1 - (var / sum(weights[i] * self.calculate_var(returns_df[area].values, confidence) 
                                               for i, area in enumerate(positions.keys())))
        }
    
    def stress_test(self, positions: Dict[str, Dict], 
                   current_prices: Dict[str, float],
                   scenario: StressScenario) -> Dict:
        """Run stress test on portfolio."""
        results = {
            'scenario': scenario.name,
            'description': scenario.description,
            'initial_value': 0.0,
            'stressed_value': 0.0,
            'pnl': 0.0,
            'positions': {}
        }
        
        for area, position in positions.items():
            current_price = current_prices.get(area, 0)
            position_size = position['size']
            position_type = position['type']  # 'long' or 'short'
            
            # Calculate initial value
            if position_type == 'long':
                initial_value = position_size * current_price
                stressed_price = current_price * (1 + scenario.price_shock)
                stressed_value = position_size * stressed_price
            else:  # short
                initial_value = position_size * current_price
                stressed_price = current_price * (1 + scenario.price_shock)
                stressed_value = position_size * (2 * current_price - stressed_price)
            
            results['initial_value'] += initial_value
            results['stressed_value'] += stressed_value
            
            results['positions'][area] = {
                'current_price': current_price,
                'stressed_price': stressed_price,
                'initial_value': initial_value,
                'stressed_value': stressed_value,
                'pnl': stressed_value - initial_value
            }
        
        results['pnl'] = results['stressed_value'] - results['initial_value']
        
        return results
    
    def check_risk_limits(self, positions: Dict[str, Dict],
                         risk_metrics: Dict) -> Dict:
        """Check if positions comply with risk limits."""
        violations = []
        warnings = []
        
        # Check position size limits
        for area, position in positions.items():
            if position['size'] > self.limits.max_position_size:
                violations.append(f"Position size in {area} exceeds limit: {position['size']:.2f} > {self.limits.max_position_size:.2f} MW")
        
        # Check daily loss limit
        if 'daily_pnl' in risk_metrics and risk_metrics['daily_pnl'] < -self.limits.max_daily_loss:
            violations.append(f"Daily loss exceeds limit: {risk_metrics['daily_pnl']:.2f} < -{self.limits.max_daily_loss:.2f} EUR")
        
        # Check drawdown limit
        if 'max_drawdown' in risk_metrics and risk_metrics['max_drawdown'] > self.limits.max_drawdown:
            violations.append(f"Maximum drawdown exceeds limit: {risk_metrics['max_drawdown']:.2f} > {self.limits.max_drawdown:.2f} EUR")
        
        # Check VaR limit
        if 'var_95' in risk_metrics and abs(risk_metrics['var_95']) > self.limits.max_var_95:
            violations.append(f"VaR (95%) exceeds limit: {abs(risk_metrics['var_95']):.2f} > {self.limits.max_var_95:.2f} EUR")
        
        # Check correlation limits
        if 'correlations' in risk_metrics:
            for pair, corr in risk_metrics['correlations'].items():
                if abs(corr) > self.limits.max_correlation:
                    warnings.append(f"High correlation between {pair}: {corr:.2f} > {self.limits.max_correlation:.2f}")
        
        return {
            'compliant': len(violations) == 0,
            'violations': violations,
            'warnings': warnings
        }
    
    def calculate_optimal_position_size(self, expected_return: float,
                                       volatility: float,
                                       confidence: float = 0.95,
                                       risk_tolerance: str = 'medium') -> float:
        """Calculate optimal position size based on risk-return profile."""
        if volatility <= 0:
            return 0.0
        
        # Risk tolerance multipliers
        tolerance_multipliers = {
            'low': 0.5,
            'medium': 1.0,
            'high': 2.0
        }
        
        multiplier = tolerance_multipliers.get(risk_tolerance, 1.0)
        
        # Kelly criterion for position sizing
        if expected_return > 0 and volatility > 0:
            # Simplified Kelly: f* = (p * b - q) / b
            # where p = win probability, b = win/loss ratio, q = 1-p
            
            # Estimate win probability from expected return and volatility
            z_score = stats.norm.ppf(confidence)
            win_prob = stats.norm.cdf(expected_return / volatility)
            
            # Estimate win/loss ratio
            win_loss_ratio = expected_return / volatility if volatility > 0 else 1.0
            
            # Kelly fraction
            kelly_fraction = (win_prob * win_loss_ratio - (1 - win_prob)) / win_loss_ratio
            
            # Adjust for risk tolerance
            position_fraction = kelly_fraction * multiplier
            
            # Cap between 0 and 1
            position_fraction = max(0.0, min(1.0, position_fraction))
            
            return position_fraction
        
        return 0.0
    
    def generate_risk_report(self, positions: Dict[str, Dict],
                           returns: Dict[str, np.ndarray],
                           current_prices: Dict[str, float]) -> Dict:
        """Generate comprehensive risk report."""
        report = {
            'timestamp': datetime.now().isoformat(),
            'positions': positions,
            'risk_metrics': {},
            'stress_tests': [],
            'limit_checks': {},
            'recommendations': []
        }
        
        # Calculate risk metrics for each position
        for area, position in positions.items():
            if area in returns:
                area_returns = returns[area]
                
                var_95 = self.calculate_var(area_returns, 0.95)
                cvar_95 = self.calculate_cvar(area_returns, 0.95)
                
                report['risk_metrics'][area] = {
                    'var_95': var_95,
                    'cvar_95': cvar_95,
                    'volatility': np.std(area_returns),
                    'sharpe': np.mean(area_returns) / np.std(area_returns) if np.std(area_returns) > 0 else 0,
                    'max_drawdown': self._calculate_max_drawdown(area_returns)
                }
        
        # Calculate portfolio-level metrics
        if len(positions) > 1:
            portfolio_var = self.calculate_portfolio_var(positions, returns)
            report['risk_metrics']['portfolio'] = portfolio_var
        
        # Run stress tests
        for scenario in self.stress_scenarios:
            stress_result = self.stress_test(positions, current_prices, scenario)
            report['stress_tests'].append(stress_result)
        
        # Check risk limits
        limit_check = self.check_risk_limits(positions, report['risk_metrics'])
        report['limit_checks'] = limit_check
        
        # Generate recommendations
        if not limit_check['compliant']:
            report['recommendations'].append("⚠️ Risk limit violations detected. Consider reducing position sizes.")
        
        if 'portfolio' in report['risk_metrics']:
            div_benefit = report['risk_metrics']['portfolio'].get('diversification_benefit', 0)
            if div_benefit < 0.1:
                report['recommendations'].append("💡 Low diversification benefit. Consider positions in less correlated areas.")
        
        # Find worst stress scenario
        worst_scenario = min(report['stress_tests'], key=lambda x: x['pnl'])
        if worst_scenario['pnl'] < -self.limits.max_daily_loss:
            report['recommendations'].append(f"⚠️ Worst stress scenario '{worst_scenario['scenario']}' could cause significant losses: €{worst_scenario['pnl']:.2f}")
        
        return report
    
    def _calculate_max_drawdown(self, returns: np.ndarray) -> float:
        """Calculate maximum drawdown from returns series."""
        cumulative = np.cumsum(returns)
        running_max = np.maximum.accumulate(cumulative)
        drawdown = running_max - cumulative
        return np.max(drawdown) if len(drawdown) > 0 else 0.0

